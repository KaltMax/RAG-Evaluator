# PostgreSQL Configuration
POSTGRES_DB=ragevaluator
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# PgAdmin Configuration
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# Ollama Configuration
OLLAMA_PORT=11434
OLLAMA_KEEP_ALIVE=24h
OLLAMA_EMBEDDING_MODELS=nomic-embed-text-v2-moe,mxbai-embed-large:v1
OLLAMA_CHAT_MODEL=qwen3.5:9b
OLLAMA_CHAT_MODEL_THINKING=false

# RAG Configuration
RAG_CHUNKING_STRATEGY=FixedSize
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=100
RAG_SIMILARITY_THRESHOLD=0.05
RAG_MIN_CHUNK_SIZE=200
RAG_PROMPT_TEMPLATE=Basic
RAG_PROMPT_BASIC=You are a helpful assistant. Answer the question based on the provided context only. If the context does not contain the answer, respond with 'I don't know.'
RAG_PROMPT_INSTRUCTED=You are a helpful assistant. Answer the question based on the provided context only. If the context does not contain the answer, respond with 'I don't know.' Always respond in the query language.
RAG_PROMPT_LANGUAGE_AWARE_EN=You are a helpful assistant. Answer the question based on the provided context only. If the context does not contain the answer, respond with 'I don't know.' Always respond in English.
RAG_PROMPT_LANGUAGE_AWARE_DE=Du bist ein hilfreicher Assistent. Beantworte die Frage basierend ausschließlich auf dem bereitgestellten Kontext. Wenn der Kontext die Antwort nicht enthält, antworte mit 'Ich weiß es nicht.' Antworte immer auf Deutsch.

# Available Courses
AVAILABLE_COURSES=Datenmanagement,Infrastruktur Grundlagen,Software Engineering III,Infrastructure as Code

# API Configuration
API_PORT=5000
ASPNETCORE_ENVIRONMENT=Development

# FileStorage Configuration
FILE_STORAGE_BASE_DIRECTORY=/app/uploads

# Web UI Configuration
WEB_UI_PORT=3000
VITE_API_URL=http://localhost:5000